[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
linux.debug.x86_64 = "res://bin/libnorrust_core.so"
linux.release.x86_64 = "res://bin/libnorrust_core.so"
windows.debug.x86_64 = "res://bin/norrust_core.dll"
windows.release.x86_64 = "res://bin/norrust_core.dll"
macos.debug = "res://bin/libnorrust_core.dylib"
macos.release = "res://bin/libnorrust_core.dylib"
